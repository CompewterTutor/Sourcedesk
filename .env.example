# SourceDesk environment configuration
# Copy to .env and edit for your setup. .env is gitignored; .env.example is committed.

# ─── Environment ──────────────────────────────────────────────────────────────
# 'file'   → SourceDesk.html opened directly from disk (some features limited by browser CORS)
# 'hosted' → served via `npm run serve` (enables local LLM, proper CORS for localhost)
ENVIRONMENT=hosted

# ─── HTTP server ──────────────────────────────────────────────────────────────
# Port used by `npm run serve`
PORT=3000

# ─── Local LLM ────────────────────────────────────────────────────────────────
# OpenAI-compatible base URL. Trailing /v1 is required.
# Ollama default:    http://localhost:11434/v1
# LM Studio default: http://localhost:1234/v1
LOCAL_LLM_URL=http://localhost:11434/v1

# Default model to pre-select when "Local LLM" provider is chosen.
# Run `ollama list` or check LM Studio to find installed model names.
LOCAL_LLM_DEFAULT_MODEL=llama3.2

# ─── MarkItDown document conversion ─────────────────────────────────────────
# Install: pip install markitdown
# The server auto-detects markitdown on PATH and exposes GET /health + POST /convert.
# Override the URL the app uses to reach the convert endpoint (defaults to this server).
# MARKITDOWN_URL=http://localhost:3000
