# ─── SourceDesk Server Configuration ─────────────────────────────────────────
# Copy this file to .env and fill in the values you need.
# The server reads .env on startup — no restart required after changes
# unless you change the PORT.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
# Label shown in startup logs (e.g. "local", "prod", "staging")
ENVIRONMENT=hosted

# ─── Local LLM (Ollama / LM Studio / llama.cpp via OpenAI-compat API) ─────────
# Used by the browser app for direct LLM calls (injected as window.__SOURCEDESK_ENV__)
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_DEFAULT_MODEL=

# ─── MarkItDown document conversion server ────────────────────────────────────
# Install: pip install "markitdown[all]"   then run: npm run serve
# The server auto-exposes /convert at its own URL — leave this pointing at the
# same host:port as the server.
MARKITDOWN_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (recommended for homelab / single-user):
#   Install: npm install better-sqlite3
#   Then just set DATABASE_URL and restart the server — migrations run automatically.
DATABASE_URL=sqlite:./data/sourcedesk.db

# PostgreSQL (recommended for multi-user / production / Docker Compose):
#   Install: npm install pg
#   Set DATABASE_URL to your connection string:
# DATABASE_URL=postgres://sourcedesk:sourcedeskpass@localhost:5432/sourcedesk

# Run migrations manually (optional — server auto-migrates on startup):
#   npm run migrate

# ─── Server-side LLM (for email summarization, analysis pipelines) ─────────────
# Provider: anthropic | openai | local
LLM_PROVIDER=anthropic

# Model used for server-side operations (email summarization, etc.)
LLM_MODEL=claude-sonnet-4-6

# API keys — only the key for your chosen LLM_PROVIDER needs to be set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# For OpenRouter: set LLM_PROVIDER=openai and OPENAI_API_KEY to your OpenRouter key.
# Set LLM_MODEL to e.g. openai/gpt-4o or google/gemini-2.5-pro-preview.

# For local LLM: set LLM_PROVIDER=local — LOCAL_LLM_URL above will be used.
# Optionally set LOCAL_LLM_KEY if your server requires an API key:
# LOCAL_LLM_KEY=

# ─── Security ─────────────────────────────────────────────────────────────────
# JWT secret — reserved for future JWT-based auth; not currently used.
# Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ─── Webhooks (optional) ──────────────────────────────────────────────────────
# Feature suggestion webhook — receives suggestion JSON via HTTP POST.
SUGGESTION_WEBHOOK_URL=
