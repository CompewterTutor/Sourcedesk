{
    "manifest_version": 3,
    "name": "SourceDesk",
    "version": "0.1.0",
    "description": "Utility tools for strategic sourcing professionals.",
    "icons": {
        "16": "images/icon-16.png",
        "32": "images/icon-32.png",
        "48": "images/icon-48.png",
        "128": "images/icon-128.png"
    },
    "background": { "service_worker": "background.js" },
    "content_scripts": [
        {
            "matches": ["https://www.bidnetdirect.com/*"],
            "js": ["content-bidnet.js"],
            "run_at": "document_idle"
        }
    ],
    "permissions": ["sidePanel", "scripting", "activeTab", "storage", "tabs"],
    "host_permissions": ["https://*.bidnetdirect.com/*"],
    "side_panel": { "default_path": "side-panel.html" },
    "action": {
        "default_icon": {
            "16": "images/icon-16.png",
            "32": "images/icon-32.png",
            "48": "images/icon-48.png",
            "128": "images/icon-128.png"
        }
    }
}
