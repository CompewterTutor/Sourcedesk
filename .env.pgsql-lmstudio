# ─────────────────────────────────────────────────────────────────────────────
# SourceDesk — pgsql-local + LM Studio (full stack)
#
# For use with:  docker compose -f docker-compose.pgsql-local.yml up -d --build
#
# Copy to .env:  cp .env.pgsql-lmstudio .env
# ─────────────────────────────────────────────────────────────────────────────


# ── PostgreSQL ────────────────────────────────────────────────────────────────
# The compose file builds the connection string from these four parts.
# POSTGRESQL_HOST defaults to host.docker.internal (your Mac from inside Docker).
# POSTGRESQL_PORT defaults to 5432.
# Leave HOST/PORT commented out unless you need to override them.

POSTGRESQL_USERNAME=sourcedesk
POSTGRESQL_PASSWORD=YOURPASSWORD
# POSTGRESQL_HOST=host.docker.internal
# POSTGRESQL_PORT=5432
#
# ⚠  sourcedesk_hindsight must exist before first run.
#    If you used docker-compose.db-only.yml it was already created.
#    Otherwise:
#      psql postgres://sourcedesk:YOURPASSWORD@localhost:5432/postgres \
#        -c "CREATE DATABASE sourcedesk_hindsight;"
#      psql postgres://sourcedesk:YOURPASSWORD@localhost:5432/sourcedesk_hindsight \
#        -c "CREATE EXTENSION IF NOT EXISTS vector;"


# ── LM Studio ─────────────────────────────────────────────────────────────────
# LM Studio runs on your Mac at port 1234 (default).
# The Docker container reaches your Mac via host.docker.internal.
#
# ⚠ IMPORTANT: LM Studio must listen on ALL interfaces (0.0.0.0), not just
# localhost — otherwise Docker containers can't reach it.
# LM Studio → Developer tab → "Serve on local network" toggle → ON

LOCAL_LLM_URL=http://host.docker.internal:1234/v1
LOCAL_LLM_DEFAULT_MODEL=google/gemma-4-26b-a4b

# Server-side LLM (email summarisation) — also via LM Studio
LLM_PROVIDER=local
LLM_MODEL=google/gemma-4-26b-a4b


# ── Cloud API keys — blank for all-local setup ────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=


# ── Hindsight memory service ──────────────────────────────────────────────────
# Both the LLM (fact extraction) and embeddings are served by LM Studio.
# LM Studio handles both models simultaneously — the embedding model is tiny
# (~few hundred MB) and barely affects the 26B model's memory footprint.
#
# provider must be "openai" here — that's Hindsight's name for the OpenAI-compat
# API format that LM Studio speaks. The API key is any non-empty string.

# Fact-extraction LLM
HINDSIGHT_LLM_PROVIDER=openai
HINDSIGHT_LLM_API_KEY=lmstudio
HINDSIGHT_LLM_MODEL=google/gemma-4-26b-a4b
HINDSIGHT_LLM_BASE_URL=http://host.docker.internal:1234/v1

# Embeddings
HINDSIGHT_EMBEDDINGS_PROVIDER=openai
HINDSIGHT_EMBEDDINGS_API_KEY=lmstudio
HINDSIGHT_EMBEDDINGS_MODEL=text-embedding-qwen3-embedding-0.6b
HINDSIGHT_EMBEDDINGS_BASE_URL=http://host.docker.internal:1234/v1


# ── Ports ─────────────────────────────────────────────────────────────────────
PORT=3000
HINDSIGHT_PORT=8888
HINDSIGHT_CTRL_PORT=9999


# ─────────────────────────────────────────────────────────────────────────────
# In-app settings (configured via Settings UI after boot — not in .env):
#
#   Settings → Provider: Local
#   LLM Base URL:    http://localhost:1234/v1
#   Model:           google/gemma-4-26b-a4b
#   Embedding model: text-embedding-qwen3-embedding-0.6b  → click Test
#
#   Settings → Server Connection
#   Server URL:  http://localhost:3000
#   API Token:   (generate with: docker compose exec web node scripts/generate_api_token.js --user you@local)
#
#   Settings → Memory (Hindsight)
#   Click Test → should show "● Connected"
#   Enable "Enable AI Memory (Recall)" checkbox
# ─────────────────────────────────────────────────────────────────────────────
