# ─────────────────────────────────────────────────────────────────────────────
# SourceDesk — Homelab Stack environment template
# Copy this to .env before first run:
#   cp .env.homelab .env
#
# Then bring up the stack:
#   docker compose -f docker-compose.homelab.yml up -d --build
#
# NOTE: Lines starting with # are comments. Remove the # to enable a variable.
# ─────────────────────────────────────────────────────────────────────────────


# ── REQUIRED — fill these in before running ───────────────────────────────────

# PostgreSQL password — used by SourceDesk, Hindsight, and your agent harnesses.
# Change this! Anything but the default.
POSTGRES_PASSWORD=change-me-strong-password

# pgAdmin web UI admin password
PGADMIN_PASSWORD=change-me-pgadmin-password


# ── LLM API keys — set whichever providers you use ────────────────────────────

ANTHROPIC_API_KEY=
OPENAI_API_KEY=


# ── SourceDesk server LLM (email summarisation) ───────────────────────────────

LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6


# ── Ports — change only if you have conflicts on your homelab ─────────────────

PORT=3000               # SourceDesk web app     → http://192.168.1.205:3000
POSTGRES_PORT=5432      # PostgreSQL              → 192.168.1.205:5432
PGADMIN_PORT=5050       # pgAdmin web UI          → http://192.168.1.205:5050
HINDSIGHT_PORT=8888     # Hindsight memory API    → http://192.168.1.205:8888
HINDSIGHT_CTRL_PORT=9999  # Hindsight control plane


# ── pgAdmin login ─────────────────────────────────────────────────────────────

PGADMIN_EMAIL=admin@homelab.local


# ── Local LLM (optional) ──────────────────────────────────────────────────────
# Point at Ollama or LM Studio running on your homelab host.
# This URL is injected into the browser app so it connects from your browser —
# use the host IP (not localhost / 127.0.0.1) so it works from any device on
# your LAN.

# LOCAL_LLM_URL=http://192.168.1.205:11434/v1    # Ollama
# LOCAL_LLM_URL=http://192.168.1.205:1234/v1     # LM Studio
# LOCAL_LLM_DEFAULT_MODEL=


# ── Hindsight memory — LLM for fact extraction ────────────────────────────────
# Defaults to Anthropic Haiku (cheap + fast). Set HINDSIGHT_LLM_API_KEY to
# your Anthropic key (it does NOT inherit from ANTHROPIC_API_KEY above).

HINDSIGHT_LLM_PROVIDER=anthropic
HINDSIGHT_LLM_API_KEY=             # set to your Anthropic key, e.g. sk-ant-...
HINDSIGHT_LLM_MODEL=claude-haiku-4-5-20251001

# ── To use a local Ollama model for Hindsight fact extraction instead: ─────────
# (Ollama must be running on the host and accessible from within the container)
#
# HINDSIGHT_LLM_PROVIDER=openai
# HINDSIGHT_LLM_API_KEY=ollama          # any non-empty string
# HINDSIGHT_LLM_MODEL=llama3.2
# HINDSIGHT_LLM_BASE_URL=http://host.docker.internal:11434/v1


# ── Hindsight memory — embeddings ─────────────────────────────────────────────
# Defaults to OpenAI text-embedding-3-small. Set HINDSIGHT_EMBEDDINGS_API_KEY
# to your OpenAI key (it does NOT inherit from OPENAI_API_KEY above).

HINDSIGHT_EMBEDDINGS_PROVIDER=openai
HINDSIGHT_EMBEDDINGS_API_KEY=         # set to your OpenAI key, e.g. sk-...
HINDSIGHT_EMBEDDINGS_MODEL=text-embedding-3-small

# ── To use local Ollama embeddings instead: ────────────────────────────────────
# nomic-embed-text is fast and high quality; pull it first:
#   ollama pull nomic-embed-text
# Then change the vector dimension in init-db/01_databases.sql to vector(768).
#
# HINDSIGHT_EMBEDDINGS_PROVIDER=openai
# HINDSIGHT_EMBEDDINGS_API_KEY=ollama   # any non-empty string
# HINDSIGHT_EMBEDDINGS_MODEL=nomic-embed-text
# HINDSIGHT_EMBEDDINGS_BASE_URL=http://host.docker.internal:11434/v1


# ── Hindsight rate limits (requests / minute per API token) ───────────────────
# Defaults are generous for interactive use. Raise if your agent harnesses
# hit these limits.

RL_RETAIN_MAX=60
RL_RECALL_MAX=120
RL_WINDOW_MS=60000
